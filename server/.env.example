PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sass_app?schema=public"

JWT_SECRET=replace_me_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# WhatsApp provider: mock | twilio | meta (see server/src/services/whatsapp/providers/)
WHATSAPP_PROVIDER=mock
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# META_PHONE_NUMBER_ID=
# META_ACCESS_TOKEN=
