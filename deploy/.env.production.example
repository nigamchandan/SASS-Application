# Production env file.
# Copy this to /srv/bizautomate/.env on the EC2 instance and fill in real values.
# DO NOT commit the real .env to git.

# --- Image registry (set by GitHub Actions on each deploy) ---
# Replace with your lowercase GitHub username/org.
IMAGE_REGISTRY=ghcr.io/your-github-user
IMAGE_TAG=latest

# --- Postgres (lives in the postgres container) ---
POSTGRES_USER=bizadmin
POSTGRES_PASSWORD=replace-with-strong-random-password
POSTGRES_DB=bizautomate

# --- Backend ---
# Generate with:  openssl rand -hex 48
JWT_SECRET=replace-with-strong-random-secret

# Used for the Express CORS allowlist. With our nginx-in-client setup, the
# browser's origin equals the EC2 public address, so set it to the same.
# After 'http://<elastic-ip>' is known, fill it in.
CLIENT_URL=http://YOUR-EC2-PUBLIC-IP
